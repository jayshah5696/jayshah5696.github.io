---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import TagList from '../../components/TagList.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allReads = (await getCollection('reads'))
    .filter((r) => !r.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return allReads.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, url, date, tags } = entry.data;
const { Content } = await render(entry);

let domain = '';
try {
  domain = new URL(url).hostname.replace('www.', '');
} catch (e) {
  domain = url;
}
---

<BaseLayout title={title} description={`Recommended read: ${title} from ${domain}`} rightSidebar={false}>
  <article>
    <!-- Back to Reads -->
    <header class="mb-10">
      <a href="/reads" class="inline-flex items-center gap-1.5 text-sm text-ink-muted dark:text-silk-muted hover:text-terra dark:hover:text-terra-light transition-colors duration-200 font-mono mb-6">
        <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        All reads
      </a>
      
      <!-- Date & Source -->
      <div class="flex items-center gap-3 mb-4 font-mono text-xs text-ink-muted dark:text-silk-muted">
        <span class="inline-flex items-center gap-1">
          <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M16 2v4M8 2v4m-5 4h18"/></svg>
          <FormattedDate date={date} />
        </span>
        <span class="text-cream-400 dark:text-night-700" aria-hidden="true">&bull;</span>
        <span class="text-gold-dark dark:text-gold-light font-medium">{domain}</span>
      </div>

      <!-- Title -->
      <h1 class="font-display text-2xl sm:text-3xl text-ink dark:text-silk leading-tight text-balance carved-heading mb-6">
        <a href={url} target="_blank" rel="noopener noreferrer" class="hover:text-terra dark:hover:text-terra-light inline-flex items-center gap-2 align-middle">
          {title}
          <svg class="size-6 shrink-0 opacity-60 hover:opacity-100 transition-opacity" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      </h1>

      <!-- Tags -->
      {tags.length > 0 && (
        <div class="mt-4">
          <TagList tags={tags} />
        </div>
      )}

      <div class="mt-10 kolam-border"></div>
    </header>

    <!-- Commentary -->
    {entry.body && entry.body.trim().length > 0 ? (
      <div class="prose prose-kolam dark:prose-invert prose-lg max-w-none">
        <Content />
      </div>
    ) : (
      <div class="featured-card p-6 border border-cream-200 dark:border-night-700 bg-cream-50/50 dark:bg-night-950/30 rounded-lg text-ink-muted dark:text-silk-muted text-center italic">
        No commentary has been written for this link. You can view the original article at <a href={url} target="_blank" rel="noopener noreferrer" class="text-terra dark:text-terra-light underline font-medium">{domain}</a>.
      </div>
    )}
  </article>
</BaseLayout>
