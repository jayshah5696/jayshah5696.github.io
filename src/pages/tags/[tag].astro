---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import ReadCard from '../../components/ReadCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter((p) => !p.data.draft);
  const reads = (await getCollection('reads')).filter((r) => !r.data.draft);
  
  const tags = [...new Set([
    ...posts.flatMap((post) => post.data.tags),
    ...reads.flatMap((read) => read.data.tags),
  ])];

  return tags.map((tag) => {
    const matchedPosts = posts
      .filter((post) => post.data.tags.includes(tag))
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
    const matchedReads = reads
      .filter((read) => read.data.tags.includes(tag))
      .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

    return {
      params: { tag },
      props: {
        tag,
        posts: matchedPosts,
        reads: matchedReads,
      },
    };
  });
}

const { tag, posts, reads } = Astro.props;
const totalCount = posts.length + reads.length;
---

<BaseLayout 
  title={`#${tag}`} 
  description={`Browse ${posts.length} posts and ${reads.length} shared links about ${tag} — by Jay Shah.`}
>
  <header class="mb-10">
    <a href="/tags" class="inline-flex items-center gap-1.5 text-sm text-ink-muted dark:text-silk-muted hover:text-terra dark:hover:text-terra-light transition-colors duration-200 font-mono mb-4">
      <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      All tags
    </a>
    <h1 class="font-display text-3xl text-ink dark:text-silk carved-heading">
      #{tag}
    </h1>
    <p class="mt-4 font-mono text-sm text-ink-muted dark:text-silk-muted tabular-nums">
      {posts.length > 0 && `${posts.length} ${posts.length === 1 ? 'post' : 'posts'}`}
      {posts.length > 0 && reads.length > 0 && ' • '}
      {reads.length > 0 && `${reads.length} shared ${reads.length === 1 ? 'link' : 'links'}`}
    </p>
  </header>

  <div class="space-y-12">
    <!-- Writings Section -->
    {posts.length > 0 && (
      <section>
        <h2 class="font-display text-xl text-ink dark:text-silk mb-5 border-b border-cream-200 dark:border-night-700 pb-2 flex items-center gap-2">
          <svg class="size-4.5 text-terra" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="9" y1="9" x2="15" y2="9"/><line x1="9" y1="13" x2="15" y2="13"/><line x1="9" y1="17" x2="11" y2="17"/></svg>
          Articles & Writings
        </h2>
        <div class="space-y-5">
          {posts.map((post) => (
            <PostCard
              title={post.data.title}
              date={post.data.date}
              description={post.data.description}
              slug={post.id}
              tags={post.data.tags}
              body={post.body ?? ''}
            />
          ))}
        </div>
      </section>
    )}

    <!-- Shared Links Section -->
    {reads.length > 0 && (
      <section>
        <h2 class="font-display text-xl text-ink dark:text-silk mb-5 border-b border-cream-200 dark:border-night-700 pb-2 flex items-center gap-2">
          <svg class="size-4.5 text-gold-dark dark:text-gold-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M6 6h10M6 10h10"/></svg>
          Shared Links & Reads
        </h2>
        <div class="space-y-5">
          {reads.map((read) => (
            <ReadCard entry={read} />
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
