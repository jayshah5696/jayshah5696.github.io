---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import RightSidebar from '../components/RightSidebar.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const totalPosts = posts.length;
---

<BaseLayout rightSidebar={true}>
  <!-- Hero welcome section -->
  <section class="mb-8">
    <p class="text-ink-light dark:text-silk-muted text-base leading-relaxed">
      Building <span class="text-terra dark:text-terra-light font-medium">LLM/RAG systems</span>,
      <span class="text-mor dark:text-mor-light font-medium">agent evaluation</span>, and
      <span class="text-gold-dark dark:text-gold-light font-medium">B2B intent intelligence</span>
      at enterprise scale -- writing about what ships.
    </p>
    <div class="flex items-center gap-3 mt-3">
      <span class="font-mono text-xs text-ink-faint dark:text-silk-faint uppercase" style="letter-spacing: 0.1em;">{totalPosts} writings</span>
      <span class="text-cream-300 dark:text-night-700 text-xs select-none" aria-hidden="true">&bull;</span>
      <a href="/rss.xml" class="font-mono text-xs text-ink-faint dark:text-silk-faint hover:text-terra dark:hover:text-terra-light transition-colors uppercase" style="letter-spacing: 0.1em;">RSS</a>
    </div>
    <div class="kolam-border mt-5"></div>
  </section>

  <div class="space-y-5">
    {posts.map((post, i) => (
      <PostCard
        title={post.data.title}
        date={post.data.date}
        description={post.data.description}
        slug={post.id}
        tags={post.data.tags}
        body={post.body ?? ''}
        image={post.data.image}
        featured={i === 0}
      />
    ))}
  </div>

  <!-- Subscribe CTA -->
  <div class="mt-12 pt-6">
    <div class="kolam-border mb-6"></div>
    <div class="flex items-center gap-4">
      <a
        href="/rss.xml"
        class="inline-flex items-center gap-2 px-4 py-2 border border-terra/20 dark:border-terra-light/20 rounded-lg text-sm font-mono text-terra dark:text-terra-light hover:bg-terra/10 dark:hover:bg-terra-light/10 transition-colors"
      >
        <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
        Subscribe via RSS
      </a>
      <span class="text-xs text-ink-faint dark:text-silk-faint font-mono">New posts in your reader</span>
    </div>
  </div>

  <RightSidebar slot="right-sidebar" />
</BaseLayout>
