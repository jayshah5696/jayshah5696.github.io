---
import { getTagColorClass, getTagIndicator } from '../utils/tags';

interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

{tags.length > 0 && (
  <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
    {tags.map((tag, i) => (
      <>
        <a href={`/tags/${tag}`} class={getTagColorClass(tag)}>
          {getTagIndicator(tag) && (
            <span class="mr-0.5 text-[8px] opacity-60" aria-hidden="true">{getTagIndicator(tag)}</span>
          )}
          {tag}
        </a>
        {i < tags.length - 1 && (
          <span class="text-cream-400 dark:text-night-700 text-xs select-none" aria-hidden="true">&bull;</span>
        )}
      </>
    ))}
  </div>
)}
