---
import { SITE_TITLE, SITE_URL } from '../consts';

interface Props {
  type: 'BlogPosting' | 'Person';
  title?: string;
  description?: string;
  date?: Date;
  image?: string;
  tags?: string[];
  url?: string;
}

const { type, title, description, date, image, tags, url } = Astro.props;

function buildSchema() {
  if (type === 'BlogPosting') {
    return {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description: description,
      datePublished: date?.toISOString(),
      dateModified: date?.toISOString(),
      image: image ? new URL(image, SITE_URL).toString() : undefined,
      url: url || new URL(Astro.url.pathname, SITE_URL).toString(),
      keywords: tags?.join(', '),
      author: {
        '@type': 'Person',
        name: SITE_TITLE,
        url: SITE_URL,
      },
      publisher: {
        '@type': 'Person',
        name: SITE_TITLE,
        url: SITE_URL,
      },
    };
  }

  if (type === 'Person') {
    return {
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: SITE_TITLE,
      url: SITE_URL,
      jobTitle: 'Senior Data Scientist',
      worksFor: {
        '@type': 'Organization',
        name: '6sense',
        url: 'https://6sense.com',
      },
      sameAs: [
        'https://github.com/jayshah5696',
        'https://twitter.com/jayjshah',
        'https://linkedin.com/in/jayshah5696',
        'https://huggingface.co/jayshah5696',
      ],
      alumniOf: {
        '@type': 'CollegeOrUniversity',
        name: 'Texas A&M University',
      },
    };
  }
}

const schema = buildSchema();
---

{schema && (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
)}
