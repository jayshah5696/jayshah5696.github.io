---
import { SITE_TITLE, SITE_TAGLINE, SOCIAL_LINKS, NAV_ITEMS } from '../consts';
import NavIcon from './NavIcon.astro';
import Search from './Search.astro';

const currentPath = Astro.url.pathname;
---

<aside class="hidden lg:flex flex-col fixed top-0 bottom-0 w-[260px] z-30 overflow-y-auto
  bg-cream-50 dark:bg-night-900 border-r border-cream-200 dark:border-night-700 app-sidebar">

  <!-- Kolam dot grid background -->
  <div class="absolute inset-0 kolam-dots pointer-events-none" aria-hidden="true"></div>

  <!-- Kolam hero pattern -->
  <div class="kolam-hero shrink-0" aria-hidden="true"></div>

  <div class="relative flex flex-col flex-1 px-5 py-5">
    <!-- Profile overlapping hero -->
    <a href="/" class="group flex flex-col items-center text-center -mt-14 mb-3">
      <div class="relative mb-3">
        <div class="absolute -inset-2 rounded-full border-2 border-dashed border-gold/40 dark:border-gold-light/30"></div>
        <img
          src="/assets/images/Profile.jpg"
          alt={SITE_TITLE}
          width="80"
          height="80"
          class="relative rounded-full size-20 object-cover group-hover:scale-105 transition-transform duration-300 ring-2 ring-white dark:ring-night-800 shadow-lg"
        />
      </div>
      <h1 class="font-display text-xl text-ink dark:text-silk">{SITE_TITLE}</h1>
      <p class="text-xs text-ink-muted dark:text-silk-muted italic mt-0.5">{SITE_TAGLINE}</p>
    </a>

    <!-- Kolam divider -->
    <div class="kolam-border my-3"></div>

    <!-- Search -->
    <div class="mb-2">
      <Search />
    </div>

    <!-- Navigation with icons -->
    <nav class="flex flex-col gap-0.5">
      {NAV_ITEMS.map(({ label, href, icon }) => {
        const isExternal = href.startsWith('http');
        const isActive = isExternal ? false : (href === '/' ? currentPath === '/' : currentPath.startsWith(href));
        return (
          <a
            href={href}
            {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            class:list={[
              'flex items-center gap-3 px-4 py-2.5 text-sm font-body rounded-lg transition-all duration-200',
              isActive
                ? 'bg-terra/10 dark:bg-terra-light/10 text-terra dark:text-terra-light font-medium'
                : 'text-ink-light dark:text-silk-muted hover:text-ink dark:hover:text-silk hover:bg-cream-100 dark:hover:bg-night-800',
            ]}
          >
            <NavIcon icon={icon} />
            {label}
            {isExternal && (
              <svg class="size-3 ml-auto opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            )}
          </a>
        );
      })}
    </nav>

    <div class="flex-1" />

    <!-- Social -->
    <div class="flex items-center justify-center gap-3 mb-3 mt-4">
      <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer" class="text-ink-faint dark:text-silk-faint hover:text-terra dark:hover:text-terra-light transition-colors" aria-label="GitHub">
        <svg class="size-[18px]" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>
      <a href={SOCIAL_LINKS.twitter} target="_blank" rel="noopener noreferrer" class="text-ink-faint dark:text-silk-faint hover:text-terra dark:hover:text-terra-light transition-colors" aria-label="X / Twitter">
        <svg class="size-[18px]" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener noreferrer" class="text-ink-faint dark:text-silk-faint hover:text-terra dark:hover:text-terra-light transition-colors" aria-label="LinkedIn">
        <svg class="size-[18px]" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
      <a href={SOCIAL_LINKS.huggingface} target="_blank" rel="noopener noreferrer" class="text-ink-faint dark:text-silk-faint hover:text-terra dark:hover:text-terra-light transition-colors" aria-label="Hugging Face">
        <svg class="size-[18px]" viewBox="0 0 1500 1500" fill="none" xmlns="http://www.w3.org/2000/svg">
