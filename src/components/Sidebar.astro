      <a href={SOCIAL_LINKS.email} class="text-ink-faint dark:text-silk-faint hover:text-terra dark:hover:text-terra-light transition-colors" aria-label="Email">
        <svg class="size-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      </a>
    </div>

    <!-- Theme toggle -->
    <button
      id="theme-toggle-desktop"
      type="button"
      class="flex items-center justify-center p-2 rounded-lg text-ink-muted dark:text-silk-muted hover:text-terra dark:hover:text-terra-light hover:bg-cream-100 dark:hover:bg-night-800 transition-all cursor-pointer mx-auto"
      aria-label="Toggle dark mode"
    >
      <svg class="size-5 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="4"/><path d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
      <svg class="size-5 block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
    </button>
  </div>
</aside>
